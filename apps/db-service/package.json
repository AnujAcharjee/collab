{
  "name": "db-service",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit",
    "db:generate": "pnpm exec prisma generate",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:migrate-reset": "pnpm exec prisma migrate reset",
    "db:prod:migrate": "pnpm exec prisma migrate deploy"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@repo/proto": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@repo/logger": "workspace:*",
    "@repo/redis": "workspace:*",
    "@repo/validation": "workspace:*",
    "chat-service": "^1.0.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/pg": "^8.18.0",
    "eslint": "^9.39.1",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
