    "@grpc/grpc-js": "^1.14.3",
    "google-protobuf": "^4.0.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.15",
    "ts-proto": "^2.11.5"
  }
}